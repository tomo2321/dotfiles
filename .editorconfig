# Stop searching for .editorconfig files in parent directories.
# This ensures the settings in this file are the definitive source for this project,
# and prevents local $HOME/.editorconfig or other parent configs from interfering.
root = true

# Global settings for all files
[*]
# Use UTF-8 encoding for characters
charset = utf-8
# Use spaces for indentation
indent_style = space
# Set indentation size to 2 spaces
indent_size = 2
# Use 'Line Feed' (Unix-style) for end-of-line characters
end_of_line = lf
# Soft limit for line length to improve readability
max_line_length = 120
# Ensure a single newline character at the end of every file
insert_final_newline = true
# Remove any whitespace characters before a line break
trim_trailing_whitespace = true

# Specific settings for Shell scripts (shfmt)
[*.sh]
# Use Bash as the shell dialect for formatting (shfmt: -ln=bash)
shell_variant = bash
# Simplify code by removing redundant syntax (shfmt: -s)
simplify_code = true
# Indent switch cases (shfmt: -ci)
switch_case_indent = true
# Binary operators start on the next line (shfmt: -bn)
binary_next_line = true
# Add spaces after redirect operators (shfmt: -sr)
space_redirects = true
