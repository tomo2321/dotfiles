[user]
	name = tomo2
	email = 30072176+tomo2321@users.noreply.github.com
[core]
	pager = less -F -X
	editor = vim
	ignorecase = false
[alias]
	st = status
	br = branch
	co = checkout
	d = diff
	ds = diff --staged
	sw = switch
	ls = ls-files
	coma = !git show-ref --verify --quiet refs/heads/main && git checkout main || git checkout master
  poh = push origin head
[init]
	defaultBranch = main
[commit]
  verbose = true
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
  compactionHeuristic = true
[color]
  ui = auto
  status = auto
  branch = auto
  grep = auto
  diff = auto
  diff-highlight = auto
[ghq]
  root = ~/ws
